# Telegram Admin Panel Environment Variables

# Development Mode (for local testing without Telegram)
# Set to 'true' to enable development mode bypass
VITE_ENABLE_DEV_MODE=false

# Development Admin ID (used only in dev mode)
# Set this to your Telegram ID for local testing
VITE_DEV_ADMIN_ID=123456789

# Production Notes:
# - VITE_ENABLE_DEV_MODE should always be 'false' or unset in production
# - The backend still requires proper ADMIN_TELEGRAM_ID configuration
# - Development mode only bypasses frontend checks, backend validation remains active